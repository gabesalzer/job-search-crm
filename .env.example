# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Firecrawl API key — get one at https://www.firecrawl.dev
FIRECRAWL_API_KEY=fc-your-key-here

# Path to the SQLite database file (relative to project root)
DATABASE_URL=sqlite:///./data/jobsearch.db

# Comma-separated keyword rules for the ingest filter (optional; can also be
# managed in-app later). Postings must contain at least one INCLUDE term and
# none of the EXCLUDE terms to be stored.
INGEST_INCLUDE_KEYWORDS=revops,revenue operations,sales operations,gtm
INGEST_EXCLUDE_KEYWORDS=unpaid,commission-only
